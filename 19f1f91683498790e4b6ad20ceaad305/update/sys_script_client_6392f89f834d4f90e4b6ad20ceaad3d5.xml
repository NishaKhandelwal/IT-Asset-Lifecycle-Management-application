        <field>purchase_date</field>
        <global>true</global>
        <isolate_script>true</isolate_script>
        <messages/>
        <name>Old asset warning </name>
        <order/>
        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading) {

    if (isLoading || !newValue)
        return;

    var purchaseDate = new Date(newValue);
    var today = new Date();

    var years = today.getFullYear() - purchaseDate.getFullYear();

    if (years >= 3) {

        g_form.showFieldMsg(
            'purchase_date',
            'This asset is over three years old and may need replacement.',
            'warning'
        );
    }
}]]></script>
